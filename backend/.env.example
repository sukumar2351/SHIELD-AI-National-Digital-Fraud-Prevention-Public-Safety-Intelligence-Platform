# SHIELD FIOS Backend Environment Settings
PROJECT_NAME="SHIELD FIOS"
API_V1_STR="/api/v1"

# JWT Auth Settings
# In production, replace this with a secure generated 32-byte hexadecimal string
JWT_SECRET="YOUR_SECURE_JWT_SECRET_HEX_HERE"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Configuration
# SQLite local default: sqlite:///./shield_fios.db
# PostgreSQL Docker default: postgresql://shield_admin:shield_fios_secure_pwd@db:5432/shield_fios
DATABASE_URL="sqlite:///./shield_fios.db"

# Mode
DEBUG=False
